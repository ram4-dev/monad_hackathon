{
  "name": "compass-proxy",
  "version": "0.1.0",
  "description": "Compass MCP security proxy for Monad — W1 skeleton + upstream adapter",
  "type": "module",
  "private": true,
  "bin": {
    "compass-proxy": "bin/compass-proxy.ts"
  },
  "scripts": {
    "dev": "bun run bin/compass-proxy.ts",
    "build": "bun build bin/compass-proxy.ts --target=bun --outdir=dist",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  }
}
